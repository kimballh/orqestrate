---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Orqestrate | Not found" description="The requested page could not be found.">
  <main class="landing-shell">
    <section class="final-cta" style="margin-top: 2rem;">
      <div>
        <p class="eyebrow">404</p>
        <h2>This route is not part of the current Orqestrate site.</h2>
        <p class="hero-lede">
          The first version of the site keeps the surface intentionally small while the product build
          is still in motion.
        </p>
      </div>
      <div class="cta-row">
        <a class="button button-primary" href="/">Back to landing page</a>
        <a class="button button-secondary" href="/docs/">Open docs</a>
      </div>
    </section>
  </main>
</BaseLayout>
