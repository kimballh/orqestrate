{
  "name": "orqestrate",
  "version": "0.1.0",
  "private": true,
  "description": "A provider-driven orchestration harness for planning, context, and agent execution.",
  "type": "module",
  "engines": {
    "node": ">=20.18.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run typecheck && npm run build && npm run test",
    "dev": "tsx src/index.ts",
    "setup": "bash ./scripts/codex-setup.sh",
    "start": "node --enable-source-maps dist/index.js",
    "test": "tsx --test $(find src -name '*.test.ts' | sort)",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@linear/sdk": "^81.0.0",
    "smol-toml": "^1.6.1"
  }
}
